  "document_blocks": [
    {
      "id": "country_intro",
      "kind": "paragraph",
      "applies_to": ["country_overview"],
      "requires": ["country.name", "country.archetype"],
      "variants": [
        "{country.name} is a fictional test country used for Country Decision Atlas development.",
        "This is a synthetic profile for {country.name}, generated for local testing.",
        "{country.name} does not exist; this overview is placeholder content for QA.",
        "The following overview of {country.name} is entirely fictional test data.",
        "{country.name} is a made-up country created solely to exercise this pipeline.",
        "No real place corresponds to {country.name}; all details here are synthetic.",
        "This profile of {country.name} was generated automatically and is not real.",
        "{country.name} appears only in test datasets and has no real-world counterpart."
      ]
    },
    {
      "id": "country_risk_summary",
      "kind": "paragraph",
      "applies_to": ["country_overview"],
      "requires": ["country.name", "country.risks"],
      "variants": [
        "For {country.name}, a key limitation remains {risk_label}.",
        "When evaluating {country.name}, consider this factor: {risk_label}.",
        "{country.name} continues to face challenges related to {risk_label}.",
        "A notable weak point for {country.name} is {risk_label}.",
        "Prospective visitors to {country.name} should note the risk factor: {risk_label}.",
        "{country.name}'s profile is constrained mainly by {risk_label}.",
        "Among the concerns for {country.name}, {risk_label} stands out.",
        "Analysts flag {risk_label} as an ongoing issue for {country.name}."
      ]
    },
    {
      "id": "country_strength_summary",
      "kind": "paragraph",
      "applies_to": ["country_overview"],
      "requires": ["country.name", "country.strengths"],
      "variants": [
        "{country.name} stands out for {strength_label}.",
        "A notable strength of {country.name} is {strength_label}.",
        "{country.name} performs particularly well on {strength_label}.",
        "One of {country.name}'s clearest advantages is {strength_label}.",
        "{country.name} is frequently praised for {strength_label}.",
        "Among {country.name}'s strong points, {strength_label} is prominent.",
        "{country.name} scores especially high on {strength_label}.",
        "A defining feature of {country.name} is its {strength_label}."
      ]
    }
  ],
