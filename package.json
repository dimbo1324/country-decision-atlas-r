{
  "name": "country-decision-atlas",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "dev": "pnpm --filter @country-decision-atlas/web dev",
    "build": "pnpm --filter @country-decision-atlas/web build",
    "lint": "pnpm --filter @country-decision-atlas/web lint",
    "typecheck": "pnpm --filter @country-decision-atlas/web typecheck",
    "contracts:generate": "openapi-typescript contracts/openapi.yaml -o packages/contracts/generated/types.ts && prettier --write packages/contracts/generated/types.ts",
    "runtime:bootstrap": "python scripts/bootstrap_runtime_read_models.py",
    "format": "python scripts/dev_tools/format_code.py",
    "format:python": "python scripts/dev_tools/format_code.py python",
    "format:frontend": "python scripts/dev_tools/format_code.py frontend",
    "format:go": "python scripts/dev_tools/format_code.py go",
    "format:prettier": "prettier --write \"package.json\" \"apps/**/*.{ts,tsx,js,jsx,json,css}\" \"packages/**/*.{ts,json}\" \"tests/e2e/**/*.ts\" \"contracts/**/*.yaml\"",
    "format:check": "prettier --check \"package.json\" \"apps/**/*.{ts,tsx,js,jsx,json,css}\" \"packages/**/*.{ts,json}\" \"tests/e2e/**/*.ts\" \"contracts/**/*.yaml\"",
    "ship:main": "python scripts/dev_tools/ship_main.py",
    "quality": "pnpm format:check && pnpm lint && pnpm typecheck && pnpm build",
    "web:mvp:e2e": "playwright test",
    "web:mvp:e2e:headed": "playwright test --headed",
    "web:mvp:e2e:report": "playwright show-report local-artifacts/playwright-report",
    "web:mvp:check": "pnpm typecheck && pnpm lint && pnpm build && pnpm runtime:bootstrap && playwright test"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "openapi-typescript": "^7.4.2",
    "prettier": "^3.3.3"
  },
  "pnpm": {
    "overrides": {
      "postcss": "8.5.10"
    }
  }
}
