{
  "name": "country-decision-atlas",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "dev": "pnpm --filter @country-decision-atlas/web dev",
    "build": "pnpm --filter @country-decision-atlas/web build",
    "lint": "pnpm --filter @country-decision-atlas/web lint",
    "typecheck": "pnpm --filter @country-decision-atlas/web typecheck",
    "contracts:generate": "openapi-typescript contracts/openapi.yaml -o packages/contracts/generated/types.ts && prettier --write packages/contracts/generated/types.ts",
    "format": "prettier --write \"**/*.{css,js,json,jsx,mjs,ts,tsx,yaml,yml}\"",
    "format:check": "prettier --check \"**/*.{css,js,json,jsx,mjs,ts,tsx,yaml,yml}\""
  },
  "devDependencies": {
    "openapi-typescript": "^7.4.2",
    "prettier": "^3.3.3"
  }
}
