# Project
APP_NAME=Country Decision Atlas
APP_ENV=local
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000

# API
API_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
API_RATE_LIMIT_PER_MINUTE=120

# Database
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_DB=country_atlas
POSTGRES_USER=country_atlas
POSTGRES_PASSWORD=change-me
DATABASE_URL=postgresql://country_atlas:change-me@localhost:5433/country_atlas

# Cache and queues
REDIS_URL=redis://localhost:6379/0

# Security
SECRET_KEY=change-me-in-local-only
ACCESS_TOKEN_EXPIRE_MINUTES=60
ADMIN_TOKEN=change-me-local-admin-token

# External data and AI providers
OPENAI_API_KEY=
SOURCE_REFRESH_ENABLED=false
