# Project
APP_NAME=Country Decision Atlas
APP_ENV=local
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000

# API
API_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
API_RATE_LIMIT_PER_MINUTE=120

# Database
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=country_atlas
POSTGRES_USER=country_atlas
POSTGRES_PASSWORD=change-me
DATABASE_URL=postgresql+psycopg://country_atlas:change-me@localhost:5432/country_atlas

# Cache and queues
REDIS_URL=redis://localhost:6379/0

# Search
MEILISEARCH_HOST=http://localhost:7700
MEILISEARCH_MASTER_KEY=change-me

# Object storage
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=country-atlas
MINIO_SECRET_KEY=change-me
MINIO_BUCKET=country-atlas-local

# Security
SECRET_KEY=change-me-in-local-only
ACCESS_TOKEN_EXPIRE_MINUTES=60

# External data and AI providers
OPENAI_API_KEY=
SOURCE_REFRESH_ENABLED=false
