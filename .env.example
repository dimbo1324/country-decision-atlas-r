# Project
APP_NAME=Country Decision Atlas
APP_ENV=local
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000

# API
API_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
API_RATE_LIMIT_PER_MINUTE=120
API_RATE_LIMIT_AUTH_PER_MINUTE=10
TRUSTED_PROXY_HEADERS=false
TRUSTED_PROXY_IPS=
ANALYTICS_ENABLED=true
ANALYTICS_SALT=local-dev-analytics-salt

# Frontend
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Database
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_DB=country_atlas
POSTGRES_USER=country_atlas
POSTGRES_PASSWORD=change-me
DATABASE_URL=postgresql://country_atlas:change-me@localhost:5433/country_atlas
DATABASE_POOL_MIN_SIZE=1
DATABASE_POOL_MAX_SIZE=10
DATABASE_POOL_TIMEOUT_SECONDS=30

# Cache and queues
CACHE_MODE=null
REDIS_URL=redis://localhost:6379/0
CACHE_NAMESPACE=cda
CACHE_DEFAULT_TTL_SECONDS=300
REDIS_CONNECT_TIMEOUT_SECONDS=0.2

# Auth
AUTH_SESSION_TTL_HOURS=168
AUTH_SESSION_TOUCH_INTERVAL_MINUTES=5
AUTH_PASSWORD_MIN_LENGTH=12
AUTH_REGISTRATION_ENABLED=true
AUTH_LOGIN_MAX_FAILED_ATTEMPTS=5
AUTH_LOGIN_FAILURE_WINDOW_SECONDS=900
AUTH_LOGIN_LOCKOUT_SECONDS=60
AUTH_LOGIN_LOCKOUT_MAX_SECONDS=900
AUTH_SESSION_ROTATION_INTERVAL_MINUTES=15
AUTH_SESSION_ROTATION_GRACE_SECONDS=30
AUTH_DEVICE_FINGERPRINT_SALT=local-dev-device-fingerprint-salt
SECURITY_HSTS_ENABLED=false
NOTIFIER_INTERNAL_AUTH_TOKEN=change-me-local-notifier-token
NOTIFIER_GRPC_ADDR=localhost:9090

# External data and AI providers
SOURCE_REFRESH_ENABLED=false
AI_MODE=fake
AI_PROVIDER=fake
AI_MODEL=fake-grounded-v1
AI_MODEL_VERSION=v1
AI_MAX_CONTEXT_ITEMS=8
AI_MAX_CONTEXT_CHARS=12000
AI_LOG_INTERACTIONS=true

# Translation provider (fake | ai)
TRANSLATION_PROVIDER=fake
AI_TRANSLATION_PROVIDER=openai
AI_TRANSLATION_MODEL=gpt-4o-mini
AI_TRANSLATION_API_KEY=
AI_TRANSLATION_TIMEOUT_SECONDS=30
AI_TRANSLATION_MAX_RETRIES=2

# Alerts (used only with --profile alerts)
KAFKA_BROKERS=redpanda:9092
KAFKA_TOPIC=cda.domain-events
KAFKA_CONSUMER_GROUP=signal-notifier
MONGO_URL=mongodb://mongo:27017
MONGO_DATABASE=country_decision_alerts
TELEGRAM_BOT_TOKEN=
TELEGRAM_MODE=fake
NOTIFY_AFTER=2026-01-01T00:00:00Z
NOTIFIER_HTTP_ADDR=:8081
GRPC_ADDR=:9090
GRPC_AUTH_TOKEN=change-me-local-notifier-token
TELEGRAM_WEB_LINK_CODE_TTL_MINUTES=10

# Production overlay only (docker-compose.prod.yml) — no default, required
REDIS_PASSWORD=
MONGO_ROOT_USERNAME=
MONGO_ROOT_PASSWORD=

# Production overlay only (docker-compose.prod.yml) — optional resource caps
POSTGRES_MEM_LIMIT=1g
REDIS_MEM_LIMIT=256m
API_MEM_LIMIT=1g
API_CPUS=2.0
REDPANDA_MEM_LIMIT=768m
REDPANDA_CPUS=1.0
MONGO_MEM_LIMIT=512m
NOTIFIER_MEM_LIMIT=256m
